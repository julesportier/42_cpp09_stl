if [[ $RAND == "true" ]]; then
	for i in {1..10}; do
		test_cases+=("$(shuf -i 1-100000 -n 3000 | tr "\n" " ")")
	done
	for i in {1..10}; do
		test_cases+=("$(shuf -r -i 1-100 -n 3000 | tr "\n" " ")")
	done
	for size in {1..100}; do
		for i in {1..10}; do
			test_cases+=("$(shuf -r -i 1-10000 -n "$size" | tr "\n" " ")")
		done
	done
fi

echo "################"
echo "# TEST SORTING #"
echo "################"
FCLEAN && MAKE all
success=0
for i in "${test_cases[@]}"; do
	echo "./PmergeMe ${i}"
	ret=$(./PmergeMe $i)
	echo -e "${ret}"
	# Check if the returned value is actually sorted.
	res=$(echo -e "${ret}" | grep "After" | sed 's/After:\s\+//' | tr ' ' '\n')
	echo "${res}" | sort --general-numeric-sort --check || success=1
done
if [[ "${success}" == 0 ]]; then
	SUCCESS "[ok]"
else
	ERROR "[ko]"
fi


if [[ $MEMORY == "true" ]]; then
	echo "###############"
	echo "# TEST MEMORY #"
	echo "###############"

	FCLEAN && MAKE all
	for i in "${test_cases[@]}"; do
		QUIET valgrind --quiet ./PmergeMe $i
	done
	FCLEAN && MAKE asan
	for i in "${test_cases[@]}"; do
		QUIET ./PmergeMe $i
	done
fi

if [[ $USAN == "true" ]]; then
	echo "###########################"
	echo "# TEST UNDEFINED BEHAVIOR #"
	echo "###########################"
	FCLEAN && MAKE usan
	for i in "${test_cases[@]}"; do
		QUIET ./PmergeMe $i
	done
fi
