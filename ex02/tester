#!/usr/bin/env bash

QUIET() {
	"${@}" 1>/dev/null
}
FCLEAN() {
	QUIET make fclean
}
MAKE() {
	QUIET make "${@}" -j"$(nproc)"
}
ERROR() {
	echo -e "\033[0;31m${*}\033[0m" >&2
}
SUCCESS() {
	echo -e "\033[0;32m${*}\033[0m"
}

RAND="false"
MEMORY="false"
USAN="false"

while getopts ":mur" opt; do
	case $opt in
		m) MEMORY="true";;
		u) USAN="true";;
		r) RAND="true";;
		\?) echo "Error: invalid option" >&2; exit 1;;
	esac
done

